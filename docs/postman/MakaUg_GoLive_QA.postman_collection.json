        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "From", "value": "whatsapp:+256760112587", "type": "text" },
            { "key": "Body", "value": "Hello", "type": "text" },
            { "key": "NumMedia", "value": "0", "type": "text" }
          ]
