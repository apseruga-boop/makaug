    {
      "name": "08 AI Motherboard",
      "item": [
        {
          "name": "8.1 Run All Enabled Agents - POST /api/admin/ai-agents/run",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "{{admin_api_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agent_code\": \"all\",\n  \"trigger_source\": \"manual_admin\",\n  \"created_by\": \"postman_qa\",\n  \"limit\": 20\n}"
            },
            "url": "{{base_url}}/api/admin/ai-agents/run"
          }
        },
        {
          "name": "8.2 List Open Findings - GET /api/admin/ai-agents/findings",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-api-key", "value": "{{admin_api_key}}" }
            ],
            "url": "{{base_url}}/api/admin/ai-agents/findings?status=open&limit=50"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (body.data && body.data.length > 0) {",
                  "    pm.environment.set('finding_id', body.data[0].id);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "8.3 Decide Finding - POST /api/admin/ai-agents/findings/:id/decision",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "{{admin_api_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"decision\": \"accepted\",\n  \"actor_id\": \"postman_admin\",\n  \"notes\": \"QA accepted\"\n}"
            },
            "url": "{{base_url}}/api/admin/ai-agents/findings/{{finding_id}}/decision"
          }
        },
        {
          "name": "8.4 List Recommended Actions - GET /api/admin/ai-agents/actions",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-api-key", "value": "{{admin_api_key}}" }
            ],
            "url": "{{base_url}}/api/admin/ai-agents/actions?status=recommended&limit=50"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (body.data && body.data.length > 0) {",
                  "    pm.environment.set('action_id', body.data[0].id);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "8.5 Approve Action - POST /api/admin/ai-agents/actions/:id/approve",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "{{admin_api_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"actor_id\": \"postman_admin\"\n}"
            },
            "url": "{{base_url}}/api/admin/ai-agents/actions/{{action_id}}/approve"
          }
        },
        {
          "name": "8.6 Execute Action (Super Admin) - POST /api/admin/ai-agents/actions/:id/execute",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "{{admin_api_key}}" },
              { "key": "x-super-admin-key", "value": "{{super_admin_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"actor_id\": \"postman_super_admin\"\n}"
            },
            "url": "{{base_url}}/api/admin/ai-agents/actions/{{action_id}}/execute"
          }
        }
      ]
    },
    {
      "name": "09 Admin Summary - GET /api/admin/summary",
      "request": {
        "method": "GET",
        "header": [
          { "key": "x-api-key", "value": "{{admin_api_key}}" }
        ],
        "url": "{{base_url}}/api/admin/summary"
