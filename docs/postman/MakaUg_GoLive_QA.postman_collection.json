{
  "info": {
    "_postman_id": "b41f3d8e-8d2f-4588-a8f2-0ad6b4e41f66",
    "name": "MakaUg - Go Live QA",
    "description": "End-to-end smoke tests for MakaUg production APIs.\n\nBefore running:\n1) Import the environment file in this same folder.\n2) Set admin_api_key + super_admin_key.\n3) Set listing_otp_code with the real OTP you receive.\n\nRun order recommendation: 01 -> 10.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 Health - GET /api/health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Health ok=true', function () { pm.expect(body.ok).to.eql(true); });"
            ]
          }
        }
      ]
    },
    {
      "name": "02 AI Model Card - GET /api/ai/model-card",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/ai/model-card"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('AI card returns capabilities', function () { pm.expect(body.ok).to.eql(true); pm.expect(body.data.capabilities.length).to.be.above(0); });"
            ]
          }
        }
      ]
    },
    {
      "name": "03 AI Rewrite Description - POST /api/ai/rewrite-description",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"listing_type\": \"sale\",\n  \"title\": \"Luxury Villa in Kololo\",\n  \"description\": \"nice house with good space\",\n  \"district\": \"Kampala\",\n  \"area\": \"Kololo\",\n  \"price\": 950000000,\n  \"bedrooms\": 5,\n  \"bathrooms\": 4,\n  \"property_type\": \"villa\",\n  \"amenities\": [\"Parking\", \"Security\", \"WiFi\"],\n  \"target_language\": \"en\"\n}"
        },
        "url": "{{base_url}}/api/ai/rewrite-description"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Rewrite returned', function () { pm.expect(body.ok).to.eql(true); pm.expect(body.data.rewritten_description).to.be.a('string'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "04 Listing Workflow",
      "item": [
        {
          "name": "4.1 Request Submit OTP - POST /api/properties/request-submit-otp",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"channel\": \"phone\",\n  \"phone\": \"{{otp_phone}}\"\n}"
            },
            "url": "{{base_url}}/api/properties/request-submit-otp"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('OTP request accepted', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const body = pm.response.json();",
                  "pm.test('OTP response ok', function () { pm.expect(body.ok).to.eql(true); });"
                ]
              }
            }
          ]
        },
        {
          "name": "4.2 Verify Submit OTP - POST /api/properties/verify-submit-otp",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"channel\": \"phone\",\n  \"phone\": \"{{otp_phone}}\",\n  \"code\": \"{{listing_otp_code}}\"\n}"
            },
            "url": "{{base_url}}/api/properties/verify-submit-otp"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('OTP verify status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('Has listing OTP token', function () { pm.expect(body.data.listing_otp_token).to.be.a('string'); });",
                  "pm.environment.set('listing_otp_token', body.data.listing_otp_token);"
                ]
              }
            }
          ]
        },
        {
          "name": "4.3 Create Property (pending) - POST /api/properties",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"listing_type\": \"sale\",\n  \"title\": \"QA Test Villa Kampala\",\n  \"district\": \"Kampala\",\n  \"area\": \"Kololo\",\n  \"description\": \"5-bedroom test listing for launch QA.\",\n  \"price\": 950000000,\n  \"listed_via\": \"website\",\n  \"lister_phone\": \"{{otp_phone}}\",\n  \"lister_email\": \"info@makaug.com\",\n  \"listing_otp_token\": \"{{listing_otp_token}}\",\n  \"verification_terms_accepted\": true,\n  \"images\": [\n    \"https://images.unsplash.com/photo-1568605114967-8130f3a36994\",\n    \"https://images.unsplash.com/photo-1570129477492-45c003edd2be\",\n    \"https://images.unsplash.com/photo-1494526585095-c41746248156\",\n    \"https://images.unsplash.com/photo-1512918728675-ed5a9ecdebfd\",\n    \"https://images.unsplash.com/photo-1505693416388-ac5ce068fe85\"\n  ]\n}"
            },
            "url": "{{base_url}}/api/properties"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create property status 201/200', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const body = pm.response.json();",
                  "pm.test('Property created', function () { pm.expect(body.ok).to.eql(true); pm.expect(body.data.id).to.exist; });",
                  "pm.environment.set('property_id', body.data.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "4.4 Get Property by ID - GET /api/properties/:id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/properties/{{property_id}}"
          }
        },
        {
          "name": "4.5 Approve Property - PATCH /api/properties/:id/status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "{{admin_api_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"approved\",\n  \"reason\": \"QA approved\"\n}"
            },
            "url": "{{base_url}}/api/properties/{{property_id}}/status"
          }
        },
        {
          "name": "4.6 Confirm Approved Property - GET /api/properties/:id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/properties/{{property_id}}"
          }
        }
      ]
    },
