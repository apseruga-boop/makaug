{
  "name": "makaug-platform",
  "version": "1.0.0",
  "private": true,
  "description": "MakaUg property platform backend and static frontend",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "dev:whatsapp-web": "node scripts/whatsapp-web-copilot.js",
    "dev:whatsapp-agent": "node scripts/whatsapp-web-agent.js",
    "dev:bot": "tsx watch src/server.ts",
    "start:bot": "node dist/server.js",
    "build:bot": "tsc -p tsconfig.json",
    "typecheck:bot": "tsc -p tsconfig.json --noEmit",
    "test:bot": "vitest run",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "admin:create-super": "node scripts/create-super-admin.js",
    "ai:export-training": "node scripts/export-ai-training-data.js",
    "ai:export-foundation": "node scripts/export-llm-foundation-data.js",
    "ai:run-agents": "node scripts/run-ai-agents.js",
    "ai:verify-whatsapp": "node scripts/verify-whatsapp-ai-provider.js",
    "test:whatsapp-conversations": "node scripts/whatsapp-conversation-self-test.js",
    "test:whatsapp-conversations:live": "WHATSAPP_SELF_TEST_BASE_URL=https://makaug.com node scripts/whatsapp-conversation-self-test.js",
    "qa:postman": "bash scripts/run-postman-qa.sh",
    "qa:postman:render": "BASE_URL=https://makaug.onrender.com bash scripts/run-postman-qa.sh",
    "qa:create-listings": "node scripts/create-qa-listings.js",
    "qa:seed-whatsapp-inventory": "node scripts/seed-whatsapp-test-inventory.js",
    "ads:daily-report": "node scripts/send-advertising-daily-reports.js",
    "check": "node --check server.js",
    "test:go-live-p0": "node tests/go-live-p0.test.js",
    "smoke": "bash scripts/smoke-test.sh",
    "prelaunch": "bash scripts/prelaunch-check.sh"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.10.1",
    "openai": "^4.104.0",
    "playwright-core": "^1.54.2",
    "pg": "^8.12.0",
    "playwright-core": "^1.59.1",
    "twilio": "^5.3.3",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.23",
    "@types/helmet": "^4.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.3",
    "nodemon": "^3.1.4",
    "supertest": "^7.1.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
