NODE_ENV=development
PORT=8080
PUBLIC_BASE_URL=https://makaug.com
APP_BASE_URL=http://localhost:8080

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/makaug
DB_SSL=false
USE_MOCK_REPOSITORIES=false

# Security / auth (existing backend)
JWT_SECRET=change-me-super-secret
JWT_EXPIRES_IN=7d
OTP_EXPIRES_MINUTES=10
ADMIN_API_KEY=change-me-admin-key
SUPER_ADMIN_KEY=change-me-super-admin-key
# Optional social sign-in. Add the matching callback URL in each provider console:
# Google: https://makaug.com/api/auth/oauth/google/callback
# Facebook: https://makaug.com/api/auth/oauth/facebook/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# AI ingest site keys are generated per-site using:
# POST /api/ai-core/sites/:siteCode/rotate-key (requires x-api-key: ADMIN_API_KEY)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# WhatsApp Business Cloud API
WHATSAPP_API_VERSION=v20.0
WHATSAPP_VERIFY_TOKEN=makaug-verify-token
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Legacy OpenAI fallback vars (optional).
# Keep empty when using only your own OpenAI-compatible/self-hosted endpoint.
OPENAI_API_KEY=
OPENAI_INTENT_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_CAMPAIGN_MODEL=gpt-4.1-mini
OPENAI_LISTING_MODEL=gpt-4.1-mini
OPENAI_REPLY_MODEL=gpt-4.1-mini

# LLM provider abstraction (for your own model infra)
# LLM_PROVIDER: openai_compat | openai | none
LLM_PROVIDER=openai_compat
# Example for self-hosted OpenAI-compatible endpoint:
# LLM_API_BASE_URL=http://localhost:8000/v1
LLM_API_BASE_URL=
# Optional. If your model server requires auth, set key.
LLM_API_KEY=
# Set true only if your OpenAI-compatible endpoint does NOT require auth header
LLM_NO_AUTH=false
# Optional org/project headers for providers that support them
LLM_ORGANIZATION=
LLM_PROJECT=
# Optional task-specific model overrides
LLM_INTENT_MODEL=
LLM_TRANSCRIBE_MODEL=
LLM_LISTING_MODEL=
LLM_REPLY_MODEL=
LLM_CAMPAIGN_MODEL=
AI_MODEL_VERSION=2026.03.27
AI_TRAINING_MIN_CONFIDENCE=0.55
AI_AGENT_RUN_LIMIT=40
AI_AGENT_TRIGGER_SOURCE=scheduled_job
AI_AGENT_CREATED_BY=system_scheduler

# External duplicate scanning for admin listing review.
# If no paid provider key is set, the backend uses a best-effort DuckDuckGo web search.
# Provider options: duckduckgo_lite | duckduckgo_html | bing | google_cse | serpapi
EXTERNAL_DUPLICATE_SCAN_PROVIDER=duckduckgo_lite
EXTERNAL_DUPLICATE_SCAN_DISABLED=false
EXTERNAL_DUPLICATE_SCAN_TIMEOUT_MS=10000
EXTERNAL_DUPLICATE_SCAN_RESULT_LIMIT=8
EXTERNAL_DUPLICATE_SCAN_CACHE_MINUTES=60
BING_SEARCH_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
SERPAPI_API_KEY=

# Optional public map provider. When set, public listing maps use Google Maps;
# without it, the site falls back to OpenStreetMap/Leaflet.
GOOGLE_MAPS_API_KEY=

# OTP / SMS
OTP_ENABLED=true
# Admin/testing OTP override (works for both email and phone verify endpoints)
# Production defaults to disabled. Prefer the admin-only QA token endpoint
# (/api/admin/listing-submit-otp-override) with ADMIN_API_KEY for testing.
ADMIN_OTP_OVERRIDE_ENABLED=false
ADMIN_OTP_OVERRIDE_CODE=
# Optional: restrict override usage to specific contacts (comma separated emails/phones)
# Example: info@makaug.com,+256760112587
ADMIN_OTP_OVERRIDE_ALLOWLIST_STRICT=true
ADMIN_OTP_OVERRIDE_ALLOWLIST=
SMS_SENDER_ID=MakaUg
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_FROM_SMS=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# Africa's Talking SMS (fallback when Twilio is not configured)
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=
AFRICASTALKING_BASE_URL=https://api.africastalking.com/version1/messaging

# Reverse geocoding
REVERSE_GEOCODE_BASE_URL=https://nominatim.openstreetmap.org/reverse
MAX_UPLOAD_BYTES=10485760
RATE_LIMIT_PER_MINUTE=120
QUEUE_POLL_SECONDS=20

# Media storage adapters
# local | supabase | s3_presigned
MEDIA_STORAGE_PROVIDER=local
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=makaug-media
S3_PRESIGN_ENDPOINT=
S3_PRESIGN_TOKEN=

# Google Analytics 4 (website telemetry)
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=replace-with-ga-api-secret

# Listing submission OTP token (existing backend)
LISTING_OTP_EXPIRES_IN=30m
LISTING_OTP_JWT_SECRET=

# Email delivery
EMAIL_FROM=MakaUg <noreply@makaug.com>
# Microsoft Graph (recommended for GoDaddy/Microsoft 365 mailboxes where SMTP auth may be disabled)
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_SENDER_EMAIL=info@makaug.com

# Direct SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_REQUIRE_AUTH=true
SMTP_TLS_REJECT_UNAUTHORIZED=true
# Optional providers (fallback order: MS Graph -> SMTP -> Resend -> Webhook)
RESEND_API_KEY=
MAIL_WEBHOOK_URL=

# Support contacts
SUPPORT_EMAIL=info@makaug.com
SUPPORT_PHONE=+256760112587

# Optional demo seed users (keep disabled in production)
SEED_DEMO_USERS=false
SEED_DEMO_FINDER_PASSWORD=
SEED_DEMO_AGENT_PASSWORD=
