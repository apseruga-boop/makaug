NODE_ENV=development
PORT=8080
APP_BASE_URL=http://localhost:8080

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/makaug
DB_SSL=false

# Security
JWT_SECRET=change-me-super-secret
JWT_EXPIRES_IN=7d
OTP_EXPIRES_MINUTES=10
ADMIN_API_KEY=change-me-admin-key
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Google Analytics 4 (optional but recommended)
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=replace-with-ga-api-secret

# Twilio WhatsApp + SMS (optional for development)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_SMS=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# App-level support contacts
SUPPORT_EMAIL=hello@makayug.com
SUPPORT_PHONE=+256770646879
